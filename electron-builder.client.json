{
  "appId": "fr.sosinfoludo.guardpilot",
  "productName": "GuardPilot Pro",
  "artifactName": "GuardPilot_Pro_Setup_${version}.exe",
  "extraMetadata": { "buildVariant": "client" },
  "directories": { "output": "dist/client" },
  "files": ["src/**/*", "assets/**/*", "package.json"],
  "win": {
    "target": [{ "target": "nsis", "arch": ["x64"] }],
    "icon": "assets/icon.ico",
    "requestedExecutionLevel": "requireAdministrator"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "menuCategory": "S.O.S INFO LUDO",
    "shortcutName": "GuardPilot Pro",
    "installerLanguages": ["fr"],
    "language": "1036"
  }
}
